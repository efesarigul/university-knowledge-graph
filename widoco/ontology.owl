<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#"
     xml:base="http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:ukg="ukg:"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:university-kg="http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg">
        <rdfs:comment xml:lang="en">Extended ontology for Manisa Celal Bayar University Engineering Faculty. Models courses, academic staff, departments, and sub-fields. Version 2 adds MandatoryCourse/ElectiveCourse subclasses, ResearchAssistant class, SubField class, extended data properties, and real data from CSE, MEE, and IE departments.</rdfs:comment>
        <rdfs:label xml:lang="en">University Knowledge Graph Ontology v2</rdfs:label>
        <rdfs:label xml:lang="tr">Üniversite Bilgi Grafiği Ontolojisi v2</rdfs:label>
        <owl:versionInfo>2.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#GPA -->


    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#GPA"/>
    


    <!-- http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#avesisURL -->


    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#avesisURL"/>
    


    <!-- http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#belongsTo -->


    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#belongsTo"/>
    


    <!-- http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#courseCode -->


    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#courseCode"/>
    


    <!-- http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#courseName -->


    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#courseName"/>
    


    <!-- http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#departmentName -->


    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#departmentName"/>
    


    <!-- http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#email -->


    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#email"/>
    


    <!-- http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#fullName -->


    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#fullName"/>
    


    <!-- http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#hasCourse -->


    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#hasCourse"/>
    


    <!-- http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#hasPrerequisite -->


    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#hasPrerequisite"/>
    


    <!-- http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#hasSubField -->


    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#hasSubField"/>
    


    <!-- http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#isEnrolledIn -->


    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#isEnrolledIn"/>
    


    <!-- http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#offeredIn -->


    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#offeredIn"/>
    


    <!-- http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#semester -->


    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#semester"/>
    


    <!-- http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#studentID -->


    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#studentID"/>
    


    <!-- http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#subFieldName -->


    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#subFieldName"/>
    


    <!-- http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#teaches -->


    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#teaches"/>
    


    <!-- http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#title -->


    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#title"/>
    


    <!-- http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#worksIn -->


    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#worksIn"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- ukg:GPA -->


    <owl:ObjectProperty rdf:about="ukg:GPA">
        <rdfs:domain rdf:resource="ukg:student"/>
        <rdfs:range rdf:resource="xsd:float"/>
    </owl:ObjectProperty>
    


    <!-- ukg:avesisURL -->


    <owl:ObjectProperty rdf:about="ukg:avesisURL">
        <rdfs:domain rdf:resource="ukg:academicStaff"/>
        <rdfs:range rdf:resource="xsd:anyURI"/>
    </owl:ObjectProperty>
    


    <!-- ukg:belongsTo -->


    <owl:ObjectProperty rdf:about="ukg:belongsTo">
        <rdfs:domain rdf:resource="ukg:person"/>
        <rdfs:range rdf:resource="ukg:department"/>
        <rdfs:comment xml:lang="en">Relates a person to their department.</rdfs:comment>
        <rdfs:label xml:lang="en">belongs to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- ukg:courseCode -->


    <owl:ObjectProperty rdf:about="ukg:courseCode">
        <rdfs:domain rdf:resource="ukg:course"/>
        <rdfs:range rdf:resource="xsd:string"/>
    </owl:ObjectProperty>
    


    <!-- ukg:courseName -->


    <owl:ObjectProperty rdf:about="ukg:courseName">
        <rdfs:domain rdf:resource="ukg:course"/>
        <rdfs:range rdf:resource="xsd:string"/>
    </owl:ObjectProperty>
    


    <!-- ukg:departmentName -->


    <owl:ObjectProperty rdf:about="ukg:departmentName">
        <rdfs:domain rdf:resource="ukg:department"/>
        <rdfs:range rdf:resource="xsd:string"/>
    </owl:ObjectProperty>
    


    <!-- ukg:email -->


    <owl:ObjectProperty rdf:about="ukg:email">
        <rdfs:domain rdf:resource="ukg:person"/>
        <rdfs:range rdf:resource="xsd:string"/>
    </owl:ObjectProperty>
    


    <!-- ukg:fullName -->


    <owl:ObjectProperty rdf:about="ukg:fullName">
        <rdfs:domain rdf:resource="ukg:person"/>
        <rdfs:range rdf:resource="xsd:string"/>
    </owl:ObjectProperty>
    


    <!-- ukg:hasCourse -->


    <owl:ObjectProperty rdf:about="ukg:hasCourse">
        <rdfs:domain rdf:resource="ukg:department"/>
        <rdfs:range rdf:resource="ukg:course"/>
        <rdfs:comment xml:lang="en">Relates a department to the courses it offers.</rdfs:comment>
        <rdfs:label xml:lang="en">has course</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- ukg:hasPrerequisite -->


    <owl:ObjectProperty rdf:about="ukg:hasPrerequisite">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="ukg:course"/>
        <rdfs:range rdf:resource="ukg:course"/>
        <rdfs:comment xml:lang="en">A course requires another course as prerequisite. Transitive.</rdfs:comment>
        <rdfs:label xml:lang="en">has prerequisite</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- ukg:hasSubField -->


    <owl:ObjectProperty rdf:about="ukg:hasSubField">
        <rdfs:domain rdf:resource="ukg:department"/>
        <rdfs:range rdf:resource="ukg:subField"/>
        <rdfs:comment xml:lang="en">Relates a department to its academic sub-fields.</rdfs:comment>
        <rdfs:label xml:lang="en">has sub-field</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- ukg:isEnrolledIn -->


    <owl:ObjectProperty rdf:about="ukg:isEnrolledIn">
        <rdfs:domain rdf:resource="ukg:student"/>
        <rdfs:range rdf:resource="ukg:course"/>
        <rdfs:label xml:lang="en">is enrolled in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- ukg:offeredIn -->


    <owl:ObjectProperty rdf:about="ukg:offeredIn">
        <rdfs:domain rdf:resource="ukg:course"/>
        <rdfs:range rdf:resource="ukg:academicTerm"/>
        <rdfs:comment xml:lang="en">Relates a course to the academic term it is offered in.</rdfs:comment>
        <rdfs:label xml:lang="en">offered in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- ukg:semester -->


    <owl:ObjectProperty rdf:about="ukg:semester">
        <rdfs:domain rdf:resource="ukg:course"/>
        <rdfs:range rdf:resource="xsd:integer"/>
    </owl:ObjectProperty>
    


    <!-- ukg:studentID -->


    <owl:ObjectProperty rdf:about="ukg:studentID">
        <rdfs:domain rdf:resource="ukg:student"/>
        <rdfs:range rdf:resource="xsd:string"/>
    </owl:ObjectProperty>
    


    <!-- ukg:subFieldName -->


    <owl:ObjectProperty rdf:about="ukg:subFieldName">
        <rdfs:domain rdf:resource="ukg:subField"/>
        <rdfs:range rdf:resource="xsd:string"/>
    </owl:ObjectProperty>
    


    <!-- ukg:supervises -->


    <owl:ObjectProperty rdf:about="ukg:supervises">
        <rdfs:domain rdf:resource="ukg:professor"/>
        <rdfs:range rdf:resource="ukg:researchAssistant"/>
        <rdfs:label xml:lang="en">supervises</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- ukg:teaches -->


    <owl:ObjectProperty rdf:about="ukg:teaches">
        <rdfs:domain rdf:resource="ukg:professor"/>
        <rdfs:range rdf:resource="ukg:course"/>
        <rdfs:label xml:lang="en">teaches</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- ukg:title -->


    <owl:ObjectProperty rdf:about="ukg:title">
        <rdfs:domain rdf:resource="ukg:academicStaff"/>
        <rdfs:range rdf:resource="xsd:string"/>
    </owl:ObjectProperty>
    


    <!-- ukg:worksIn -->


    <owl:ObjectProperty rdf:about="ukg:worksIn">
        <rdfs:domain rdf:resource="ukg:academicStaff"/>
        <rdfs:range rdf:resource="ukg:subField"/>
        <rdfs:comment xml:lang="en">Relates an academic staff member to their sub-field (anabilim dalı).</rdfs:comment>
        <rdfs:label xml:lang="en">works in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- ukg:GPA -->


    <owl:DatatypeProperty rdf:about="ukg:GPA"/>
    


    <!-- ukg:avesisURL -->


    <owl:DatatypeProperty rdf:about="ukg:avesisURL"/>
    


    <!-- ukg:courseCode -->


    <owl:DatatypeProperty rdf:about="ukg:courseCode"/>
    


    <!-- ukg:courseName -->


    <owl:DatatypeProperty rdf:about="ukg:courseName"/>
    


    <!-- ukg:departmentName -->


    <owl:DatatypeProperty rdf:about="ukg:departmentName"/>
    


    <!-- ukg:email -->


    <owl:DatatypeProperty rdf:about="ukg:email"/>
    


    <!-- ukg:fullName -->


    <owl:DatatypeProperty rdf:about="ukg:fullName"/>
    


    <!-- ukg:semester -->


    <owl:DatatypeProperty rdf:about="ukg:semester"/>
    


    <!-- ukg:studentID -->


    <owl:DatatypeProperty rdf:about="ukg:studentID"/>
    


    <!-- ukg:subFieldName -->


    <owl:DatatypeProperty rdf:about="ukg:subFieldName"/>
    


    <!-- ukg:title -->


    <owl:DatatypeProperty rdf:about="ukg:title"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#academicTerm -->


    <owl:Class rdf:about="http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#academicTerm"/>
    


    <!-- http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#department -->


    <owl:Class rdf:about="http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#department"/>
    


    <!-- http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#electiveCourse -->


    <owl:Class rdf:about="http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#electiveCourse"/>
    


    <!-- http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#mandatoryCourse -->


    <owl:Class rdf:about="http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#mandatoryCourse"/>
    


    <!-- http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#professor -->


    <owl:Class rdf:about="http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#professor"/>
    


    <!-- http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#researchAssistant -->


    <owl:Class rdf:about="http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#researchAssistant"/>
    


    <!-- http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#student -->


    <owl:Class rdf:about="http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#student"/>
    


    <!-- http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#subField -->


    <owl:Class rdf:about="http://www.semanticweb.org/ayca/ontologies/2026/3/university-kg#subField"/>
    


    <!-- ukg:academicStaff -->


    <owl:Class rdf:about="ukg:academicStaff">
        <rdfs:subClassOf rdf:resource="ukg:person"/>
        <rdfs:label xml:lang="en">Academic Staff</rdfs:label>
    </owl:Class>
    


    <!-- ukg:academicTerm -->


    <owl:Class rdf:about="ukg:academicTerm">
        <rdfs:comment xml:lang="en">A semester or academic period (Fall, Spring).</rdfs:comment>
        <rdfs:label xml:lang="en">Academic Term</rdfs:label>
    </owl:Class>
    


    <!-- ukg:course -->


    <owl:Class rdf:about="ukg:course">
        <rdfs:comment xml:lang="en">A course offered by a department.</rdfs:comment>
        <rdfs:label xml:lang="en">Course</rdfs:label>
    </owl:Class>
    


    <!-- ukg:department -->


    <owl:Class rdf:about="ukg:department">
        <rdfs:comment xml:lang="en">An engineering department at MCBU.</rdfs:comment>
        <rdfs:label xml:lang="en">Department</rdfs:label>
    </owl:Class>
    


    <!-- ukg:electiveCourse -->


    <owl:Class rdf:about="ukg:electiveCourse">
        <rdfs:subClassOf rdf:resource="ukg:course"/>
        <owl:disjointWith rdf:resource="ukg:mandatoryCourse"/>
        <rdfs:comment xml:lang="en">A course that students can optionally select (Seçmeli).</rdfs:comment>
        <rdfs:label xml:lang="en">Elective Course</rdfs:label>
    </owl:Class>
    


    <!-- ukg:mandatoryCourse -->


    <owl:Class rdf:about="ukg:mandatoryCourse">
        <rdfs:subClassOf rdf:resource="ukg:course"/>
        <rdfs:comment xml:lang="en">A course that is compulsory for students (Zorunlu).</rdfs:comment>
        <rdfs:label xml:lang="en">Mandatory Course</rdfs:label>
    </owl:Class>
    


    <!-- ukg:person -->


    <owl:Class rdf:about="ukg:person">
        <rdfs:label xml:lang="en">Person</rdfs:label>
    </owl:Class>
    


    <!-- ukg:professor -->


    <owl:Class rdf:about="ukg:professor">
        <rdfs:subClassOf rdf:resource="ukg:academicStaff"/>
        <rdfs:comment xml:lang="en">Full professor, associate professor, or assistant professor (Öğretim Üyesi).</rdfs:comment>
        <rdfs:label xml:lang="en">Professor / Lecturer</rdfs:label>
    </owl:Class>
    


    <!-- ukg:researchAssistant -->


    <owl:Class rdf:about="ukg:researchAssistant">
        <rdfs:subClassOf rdf:resource="ukg:academicStaff"/>
        <rdfs:label xml:lang="en">Research Assistant (Araştırma Görevlisi)</rdfs:label>
    </owl:Class>
    


    <!-- ukg:student -->


    <owl:Class rdf:about="ukg:student">
        <rdfs:subClassOf rdf:resource="ukg:person"/>
        <rdfs:label xml:lang="en">Student</rdfs:label>
    </owl:Class>
    


    <!-- ukg:subField -->


    <owl:Class rdf:about="ukg:subField">
        <rdfs:comment xml:lang="en">Academic sub-field within a department.</rdfs:comment>
        <rdfs:label xml:lang="en">Sub-Field (Anabilim Dalı)</rdfs:label>
    </owl:Class>
    


    <!-- xsd:string -->


    <owl:Class rdf:about="xsd:string"/>
    


