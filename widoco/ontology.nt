<ukg:academicTerm> <http://www.w3.org/2000/01/rdf-schema#comment> "A semester or academic period (Fall, Spring)."@en .
<ukg:academicTerm> <http://www.w3.org/2000/01/rdf-schema#label> "Academic Term"@en .
# 
# ukg:course
<ukg:course> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<ukg:course> <http://www.w3.org/2000/01/rdf-schema#comment> "A course offered by a department."@en .
<ukg:course> <http://www.w3.org/2000/01/rdf-schema#label> "Course"@en .
# 
# ukg:department
<ukg:department> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<ukg:department> <http://www.w3.org/2000/01/rdf-schema#comment> "An engineering department at MCBU."@en .
<ukg:department> <http://www.w3.org/2000/01/rdf-schema#label> "Department"@en .
# 
# ukg:electiveCourse
<ukg:electiveCourse> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<ukg:electiveCourse> <http://www.w3.org/2000/01/rdf-schema#subClassOf> <ukg:course> .
<ukg:electiveCourse> <http://www.w3.org/2002/07/owl#disjointWith> <ukg:mandatoryCourse> .
<ukg:electiveCourse> <http://www.w3.org/2000/01/rdf-schema#comment> "A course that students can optionally select (Seçmeli)."@en .
<ukg:electiveCourse> <http://www.w3.org/2000/01/rdf-schema#label> "Elective Course"@en .
# 
# ukg:mandatoryCourse
<ukg:mandatoryCourse> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<ukg:mandatoryCourse> <http://www.w3.org/2000/01/rdf-schema#subClassOf> <ukg:course> .
<ukg:mandatoryCourse> <http://www.w3.org/2000/01/rdf-schema#comment> "A course that is compulsory for students (Zorunlu)."@en .
<ukg:mandatoryCourse> <http://www.w3.org/2000/01/rdf-schema#label> "Mandatory Course"@en .
# 
# ukg:person
